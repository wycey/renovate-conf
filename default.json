{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticPrefixChore",
    ":semanticCommitScope(deps)",
    ":automergeMinor",
    "schedule:daily"
  ],
  "baseBranchPatterns": ["$default"],
  "configMigration": true,
  "autoApprove": true,
  "minimumReleaseAge": "3 days",
  "timezone": "Asia/Tokyo",
  "reviewers": ["team:developers"],
  "labels": ["deps"],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "assignees": ["@instructr13"]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "rollback": {
    "autoApprove": false,
    "automerge": false,
    "addLabels": ["hotfix"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "groupName": "Enable automerge for devDependencies",
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    }
  ]
}
